# Root .gitignore for Xeno CRM Application

# Python virtual environment
venv/
.venv/
ENV/
env/

# Python cache / compile files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/

# Node dependencies
node_modules/
frontend/node_modules/

# Next.js build output
frontend/.next/
frontend/out/
frontend/build/

# Local databases / JSON stores
crm_database.json
*.db
*.sqlite

# Environment variables & secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
